{
  "name": "insights",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack",
    "start": "next start",
    "lint": "eslint src",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "merge-env": "node scripts/merge-env-from-example.mjs",
    "merge-env:apply": "node scripts/merge-env-from-example.mjs --write",
    "regen-logo-assets": "node scripts/regen-logo-assets.mjs"
  },
  "dependencies": {
    "@clerk/localizations": "^4.2.4",
    "@clerk/nextjs": "^7.0.7",
    "@clerk/themes": "^2.4.57",
    "@marsidev/react-turnstile": "^1.5.0",
    "@opennextjs/cloudflare": "^1.18.0",
    "jsonrepair": "^3.13.3",
    "next": "^16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
