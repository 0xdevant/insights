# =============================================================================
# CrawlMe — copy to `.env.local` (next dev) and/or `.dev.vars` + Worker secrets
# (Cloudflare: Workers → Settings → Variables and Secrets). Do not commit real values.
# KV / R2: see `DEPLOY.md` (wrangler.jsonc bindings, not env vars here).
# =============================================================================

# --- Core (required for /api/scan) ---
VENICE_API_KEY=

# --- AI (optional; default openai-gpt-54-mini / GPT-5.4 Mini if unset) ---
# VENICE_MODEL=openai-gpt-54-mini
# Wall-clock timeout for each Venice chat/completions call (ms). Default 180000 (3 min).
# VENICE_FETCH_TIMEOUT_MS=180000
# "Venice returned empty content" in prod: often a reasoning-only reply / provider quirk — try another model or shorter prompt (see venice.ts diagnostics in the error).

# --- Competitor URLs (web search → Venice filter; optional) ---
# TAVILY_API_KEY=                 # https://tavily.com — short natural-language query (not Google operators)
# BRAVE_SEARCH_API_KEY=         # https://brave.com/search/api/ — full SERP-style query
# If both are set, competitor discovery merges Tavily + Brave results before the AI filter.
# CRAWLME_COMPETITOR_DISCOVERY= # tavily | brave | model | none — omit = auto: Tavily if TAVILY_API_KEY, else Brave if BRAVE_SEARCH_API_KEY, else Venice model-only

# --- Public URL (production: set to your canonical origin for Stripe checkout return URLs) ---
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Clerk (auth — required in production: middleware runs on all routes) ---
# Build (CI): set NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY in GitHub Actions secrets.
# Runtime (Worker): wrangler secret put CLERK_SECRET_KEY — both from the same Clerk instance.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...

# --- Cloudflare Turnstile (recommended for production: protects free scans from bots) ---
# https://developers.cloudflare.com/turnstile/
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Stripe (one-time US$18 Pro unlock; amount/product hardcoded in app) ---
# STRIPE_SECRET_KEY=sk_...
# Webhook signing secret (checkout.session.completed):
# STRIPE_WEBHOOK_SECRET=whsec_...
# Local: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# --- Crawl breadth (same-site extra pages after primary URL) ---
# Free: 2 extra pages (3 total); Pro: 5 extra (6 total). Override with:
# CRAWLME_EXTRA_SITE_PAGES=4

# --- Quotas & abuse (production tuning) ---
# FREE_GLOBAL_DAILY_SCANS=100
# CRAWLME_QUOTA_BYPASS_IPS=203.0.113.10

# --- Google PageSpeed Insights API (optional; Lighthouse lab scores on /api/scan) ---
# Enable "PageSpeed Insights API" in Google Cloud Console, then create an API key.
# https://developers.google.com/speed/docs/insights/v5/get-started
# GOOGLE_PAGESPEED_API_KEY=

# --- Admin (optional; /api/admin/benchmark) ---
# CRAWLME_ADMIN_SECRET=

# --- Local development only (never enable in production) ---
# CRAWLME_QUOTA_BYPASS_DEV=true
